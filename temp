# Your configuration
column_types = {
    "TransactionID": "INT",
    "ServiceDate": "DATE",
    "RateAmount": "DECIMAL(18,2)",
    "ProviderNPI": "BIGINT"
}

staging_table = "stg_AmbulanceRates"
problem_table = "stg_AmbulanceRates_Errors"

# 1. Build the list of columns for the SELECT statement
columns_str = ", ".join([f"[{col}]" for col in column_types.keys()])

# 2. Build the WHERE clause to find ANY failure
# Logic: TRY_CAST is NULL but the original value was NOT NULL
where_conditions = [
    f"(TRY_CAST([{col}] AS {dtype}) IS NULL AND [{col}] IS NOT NULL)" 
    for col, dtype in column_types.items()
]
where_clause = " OR ".join(where_conditions)

# 3. Build the CASE statement to identify WHICH column failed
reason_cases = [
    f"WHEN TRY_CAST([{col}] AS {dtype}) IS NULL AND [{col}] IS NOT NULL THEN 'Invalid {dtype}: ' + [{col}]"
    for col, dtype in column_types.items()
]
reason_clause = "CASE " + " ".join(reason_cases) + " ELSE 'Multiple Validation Failures' END"

# 4. Construct the final SQL
sql = f"""
INSERT INTO {problem_table} ({columns_str}, ErrorReason)
SELECT {columns_str}, {reason_clause}
FROM {staging_table}
WHERE {where_clause};

-- Optional: Remove the problem rows from staging after diverting
DELETE FROM {staging_table}
WHERE {where_clause};
"""

